// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  ADMIN
}

enum VouchStatus {
  ACTIVE
  FLAGGED
  REMOVED
}

enum TicketStatus {
  OPEN          // awaiting staff, or the user just replied
  IN_PROGRESS   // staff is actively working it
  RESOLVED      // staff considers it done; user can reopen by replying
  CLOSED        // archived; no further replies
}

enum TicketCategory {
  ISSUE
  SUGGESTION
  BILLING
  ACCOUNT
  OTHER
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model User {
  id               String    @id @default(cuid())
  name             String?
  username         String?   @unique
  email            String?   @unique
  password         String?
  role             Role      @default(USER)
  emailVerified    DateTime?
  image            String?
  accounts         Account[]
  sessions         Session[]

  // Business Logic Fields
  slug             String?   @unique
  discordId        String?   @unique
  telegramId       String?   @unique
  isPremium        Boolean   @default(false)
  premiumExpiresAt  DateTime? // null = no expiry tracked; set/extended by the payments webhook
  paymentCustomerId String?  @unique // customer id from the external payments site
  discordBotToken  String?
  telegramBotToken String?
  customDomain     String?  @unique
  vouchesReceived  Vouch[]   @relation("ReceivedVouches")
  blacklist        Blacklist[]
  guildConfigs     GuildConfig[]
  supportTickets   SupportTicket[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  // Live bot health, written by the bot manager on each spawn/teardown so the
  // dashboard can show real status instead of "a token exists".
  discordBotOnline  Boolean   @default(false)
  telegramBotOnline Boolean   @default(false)
  botCheckedAt      DateTime?

  // TOTP 2FA
  totpEnabled          Boolean   @default(false)
  totpSecret           String?   // AES-256-GCM encrypted via crypto.ts
  totpPendingSecret    String?   // temporary during setup; cleared on confirm/cancel

  // Moderation: a reversible ban. When bannedAt is set the user cannot sign in
  // (credentials or magic link) and their public profile/vouches are hidden,
  // but all data is retained so an admin can review and unban.
  bannedAt             DateTime?
  banReason            String?

  // Timestamp of the last payments webhook applied to this user — used to drop
  // stale/replayed/out-of-order events (the source signs each with a timestamp).
  lastWebhookAt        DateTime?
  // When the last weekly reputation summary was sent — makes the weekly job
  // resilient to process restarts instead of depending on an exact-hour tick.
  lastWeeklySummaryAt  DateTime?

  // Bot Customization - Vouch Command
  vouchEmbedTitle        String   @default("New vouch created!")
  vouchEmbedFooter       String   @default("Powered by Vouched.to")
  vouchEmbedColor        String   @default("#5865F2")
  vouchEmbedDescription  String?
  vouchEmbedAuthorName   String?
  vouchEmbedAuthorIconUrl String?
  vouchEmbedThumbnailUrl  String?
  vouchEmbedFooterIconUrl String?
  vouchEmbedTimestamp    Boolean  @default(true)
  vouchRequireProof      Boolean  @default(false)
  vouchShowCount         Boolean  @default(true)
  vouchTagUser           Boolean  @default(true)
  vouchChannelId         String?
  vouchRoleId            String?
  vouchEmoji             String?

  // Bot Customization - Stats Command
  statsEmbedTitle          String   @default("Vouched.to Profile Stats")
  statsEmbedDescription    String   @default("Showing my Vouched.to profile stats!")
  statsEmbedFooter         String   @default("Powered by Vouched.to")
  statsEmbedColor          String   @default("#5865F2")
  statsEmbedAuthorName     String?
  statsEmbedAuthorIconUrl  String?
  statsEmbedThumbnailUrl   String?
  statsEmbedFooterIconUrl  String?
  statsShowCount           Boolean  @default(true)
  statsShowScore           Boolean  @default(true)
  statsShowLeaderboard     Boolean  @default(true)
  statsShowPlan            Boolean  @default(true)
  statsShowExpiration      Boolean  @default(true)
  statsShowAge             Boolean  @default(true)

  // Web Profile Customization
  profileTheme           String   @default("dark")
  profileAccentColor     String   @default("#6366f1")
  profileBannerImage     String?
  profileMetaTitle       String?
  profileMetaDescription String?
  profileFontFamily      String   @default("sans")
  profileDesignTokens    Json?
  profileShowStats       Boolean  @default(true)
  profileShowBadges      Boolean  @default(true)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Vouch {
  id              String   @id @default(uuid())
  receiverId      String
  platform        String   // "discord" or "telegram"
  giverId         String   // ID of the person who left the vouch
  giverName       String
  sourceId        String   // Server ID or Telegram Group ID
  rating          Int      // 1-5
  comment         String?
  proofImageUrl   String?  // Cloudflare R2 URL
  status          VouchStatus @default(ACTIVE) // ACTIVE | FLAGGED | REMOVED (soft-delete)
  autoFlagReason  String?  // set by automated content screening; null = no auto-flag
  type            String?  // sale | service | trade | other
  sourceName      String?  // server / group name for context
  sellerReply     String?
  editedAt        DateTime?
  createdAt       DateTime @default(now())

  receiver        User          @relation("ReceivedVouches", fields: [receiverId], references: [id], onDelete: Cascade)
  reports         VouchReport[]

  @@index([receiverId, createdAt])
}

model Blacklist {
  id        String   @id @default(cuid())
  userId    String   // owner
  platform  String   // discord | telegram
  blockedId String   // giver id
  reason    String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform, blockedId])
}

model VouchReport {
  id         String   @id @default(cuid())
  vouchId    String
  reporterId String
  reason     String?
  createdAt  DateTime @default(now())

  vouch      Vouch    @relation(fields: [vouchId], references: [id], onDelete: Cascade)
}

model GuildConfig {
  id                String   @id @default(cuid())
  userId            String   // owning bot user
  guildId           String   // Discord guild / Telegram chat id
  vouchChannelId    String?
  pinnedMessageId   String?
  requireProof      Boolean  @default(false)
  minAccountAgeDays Int      @default(0)
  createdAt         DateTime @default(now())

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, guildId])
}

// Append-only record of privileged admin actions (bans, deletes, premium grants,
// role changes, moderation, settings toggles). actorEmail is denormalized so the
// trail survives if the admin account is later deleted. Not FK-linked to User for
// the same reason.
model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String?  // admin user id at time of action
  actorEmail String?  // denormalized admin identity, survives actor deletion
  action     String   // e.g. USER_BAN, USER_DELETE, PREMIUM_GRANT, ROLE_CHANGE
  targetType String   // user | vouch | setting
  targetId   String?
  summary    String   // human-readable description shown in the admin UI
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// Key/value store for runtime-toggleable global flags (e.g. signups_paused).
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// A support ticket raised by a user (issue, suggestion, billing, etc). The body
// of the conversation lives in TicketMessage rows; the ticket carries workflow
// state. `awaitingStaff` is denormalized from the last message's author so the
// admin queue can sort/badge "needs a reply" without scanning messages (mirrors
// how the flagged-vouch count drives the admin nav badge).
model SupportTicket {
  id            String         @id @default(cuid())
  userId        String
  subject       String
  category      TicketCategory @default(ISSUE)
  status        TicketStatus   @default(OPEN)
  priority      TicketPriority @default(NORMAL)
  lastMessageAt DateTime       @default(now()) // queue sort key
  awaitingStaff Boolean        @default(true)  // last message was from the user
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages TicketMessage[]

  @@index([status, lastMessageAt])
  @@index([userId, createdAt])
}

// One message in a ticket thread. authorName/authorRole are denormalized so the
// thread renders correctly (and survives) even if the author account is later
// deleted. `internal` messages are staff-only notes never shown or emailed to
// the user.
model TicketMessage {
  id         String   @id @default(cuid())
  ticketId   String
  authorId   String?  // null if the author was later deleted
  authorName String   // denormalized display name, survives deletion
  authorRole Role     // USER | ADMIN — drives bubble alignment
  body       String   @db.Text
  internal   Boolean  @default(false) // staff-only note, hidden from the user
  createdAt  DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}


