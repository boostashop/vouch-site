// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  ADMIN
}

enum VouchStatus {
  ACTIVE
  FLAGGED
  REMOVED
}

model User {
  id               String    @id @default(cuid())
  name             String?
  username         String?   @unique
  email            String?   @unique
  password         String?
  role             Role      @default(USER)
  emailVerified    DateTime?
  image            String?
  accounts         Account[]
  sessions         Session[]

  // Business Logic Fields
  slug             String?   @unique
  discordId        String?   @unique
  telegramId       String?   @unique
  isPremium        Boolean   @default(false)
  premiumExpiresAt  DateTime? // null = no expiry tracked; set/extended by the payments webhook
  paymentCustomerId String?  @unique // customer id from the external payments site
  discordBotToken  String?
  telegramBotToken String?
  customDomain     String?  @unique
  vouchesReceived  Vouch[]   @relation("ReceivedVouches")
  blacklist        Blacklist[]
  guildConfigs     GuildConfig[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  // Live bot health, written by the bot manager on each spawn/teardown so the
  // dashboard can show real status instead of "a token exists".
  discordBotOnline  Boolean   @default(false)
  telegramBotOnline Boolean   @default(false)
  botCheckedAt      DateTime?

  // Timestamp of the last payments webhook applied to this user — used to drop
  // stale/replayed/out-of-order events (the source signs each with a timestamp).
  lastWebhookAt        DateTime?
  // When the last weekly reputation summary was sent — makes the weekly job
  // resilient to process restarts instead of depending on an exact-hour tick.
  lastWeeklySummaryAt  DateTime?

  // Bot Customization - Vouch Command
  vouchEmbedTitle        String   @default("New vouch created!")
  vouchEmbedFooter       String   @default("Powered by Vouched.to")
  vouchEmbedColor        String   @default("#5865F2")
  vouchEmbedDescription  String?
  vouchEmbedAuthorName   String?
  vouchEmbedAuthorIconUrl String?
  vouchEmbedThumbnailUrl  String?
  vouchEmbedFooterIconUrl String?
  vouchEmbedTimestamp    Boolean  @default(true)
  vouchRequireProof      Boolean  @default(false)
  vouchShowCount         Boolean  @default(true)
  vouchTagUser           Boolean  @default(true)
  vouchChannelId         String?
  vouchRoleId            String?
  vouchEmoji             String?

  // Bot Customization - Stats Command
  statsEmbedTitle          String   @default("Vouched.to Profile Stats")
  statsEmbedDescription    String   @default("Showing my Vouched.to profile stats!")
  statsEmbedFooter         String   @default("Powered by Vouched.to")
  statsEmbedColor          String   @default("#5865F2")
  statsEmbedAuthorName     String?
  statsEmbedAuthorIconUrl  String?
  statsEmbedThumbnailUrl   String?
  statsEmbedFooterIconUrl  String?
  statsShowCount           Boolean  @default(true)
  statsShowScore           Boolean  @default(true)
  statsShowLeaderboard     Boolean  @default(true)
  statsShowPlan            Boolean  @default(true)
  statsShowExpiration      Boolean  @default(true)
  statsShowAge             Boolean  @default(true)

  // Web Profile Customization
  profileTheme           String   @default("dark")
  profileAccentColor     String   @default("#6366f1")
  profileBannerImage     String?
  profileMetaTitle       String?
  profileMetaDescription String?
  profileFontFamily      String   @default("sans")
  profileDesignTokens    Json?
  profileShowStats       Boolean  @default(true)
  profileShowBadges      Boolean  @default(true)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Vouch {
  id              String   @id @default(uuid())
  receiverId      String
  platform        String   // "discord" or "telegram"
  giverId         String   // ID of the person who left the vouch
  giverName       String
  sourceId        String   // Server ID or Telegram Group ID
  rating          Int      // 1-5
  comment         String?
  proofImageUrl   String?  // Cloudflare R2 URL
  status          VouchStatus @default(ACTIVE) // ACTIVE | FLAGGED | REMOVED (soft-delete)
  type            String?  // sale | service | trade | other
  sourceName      String?  // server / group name for context
  sellerReply     String?
  editedAt        DateTime?
  createdAt       DateTime @default(now())

  receiver        User          @relation("ReceivedVouches", fields: [receiverId], references: [id], onDelete: Cascade)
  reports         VouchReport[]

  @@index([receiverId, createdAt])
}

model Blacklist {
  id        String   @id @default(cuid())
  userId    String   // owner
  platform  String   // discord | telegram
  blockedId String   // giver id
  reason    String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform, blockedId])
}

model VouchReport {
  id         String   @id @default(cuid())
  vouchId    String
  reporterId String
  reason     String?
  createdAt  DateTime @default(now())

  vouch      Vouch    @relation(fields: [vouchId], references: [id], onDelete: Cascade)
}

model GuildConfig {
  id                String   @id @default(cuid())
  userId            String   // owning bot user
  guildId           String   // Discord guild / Telegram chat id
  vouchChannelId    String?
  pinnedMessageId   String?
  requireProof      Boolean  @default(false)
  minAccountAgeDays Int      @default(0)
  createdAt         DateTime @default(now())

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, guildId])
}


